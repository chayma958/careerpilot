PORT=4000
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# Local Postgres via Docker (recommended for dev — no network flakiness or connection limits):
#   docker run -d --name careerpilot-postgres -e POSTGRES_USER=careerpilot \
#     -e POSTGRES_PASSWORD=careerpilot -e POSTGRES_DB=careerpilot -p 5433:5432 postgres:17-alpine
DATABASE_URL=postgresql://careerpilot:careerpilot@localhost:5433/careerpilot

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Sign up free at resend.com, verify your account email, then create an API key
# (Dashboard > API Keys). Without a verified custom domain, EMAIL_FROM must use
# their sandbox domain and you can only send to the email you signed up with —
# fine for solo/dev use, verify a domain later to email other users.
RESEND_API_KEY=
EMAIL_FROM=CareerPilot <onboarding@resend.dev>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Free (rate-limited) models, no billing required: openrouter.ai/keys
OPENROUTER_API_KEY=

# Used by `npm run db:seed` and shown on the login page's demo callout — keep in sync
# between here and frontend/.env (VITE_DEMO_EMAIL / VITE_DEMO_PASSWORD).
DEMO_EMAIL=demo@careerpilot.dev
DEMO_PASSWORD=Demo1234!

